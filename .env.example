# Database Settings
# Note: For running via Docker, replace 'localhost' with the service name 'db' (e.g. postgresql+asyncpg://postgres:postgres@db:5432/fastapi)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi

# Redis Settings
# Note: For running via Docker, replace 'localhost' with the service name 'redis' (e.g. redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0

# Security Settings
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=yoursecretkeyherechangeitinproduction

# Application Config
ENVIRONMENT=development
DEBUG=True

# Network and CORS
CORS_ORIGINS=["*"]
TRUSTED_HOSTS=["*"]
